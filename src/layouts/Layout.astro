---
import '../styles/global.css';
import { getSessionProfile, SESSION_COOKIE, IMPERSONATE_COOKIE } from '../lib/session';
import { supabase } from '../lib/supabase';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const { title = 'PvP Arena', description = 'Sistema de evaluacion PvP', showNav = true } = Astro.props;

const token = Astro.cookies.get(SESSION_COOKIE)?.value;
const profile = token ? await getSessionProfile(token) : null;
const isLoggedIn = !!profile;
const isAdmin    = profile?.role === 'admin';
const pathname   = Astro.url.pathname;

const isImpersonating = !!Astro.cookies.get(IMPERSONATE_COOKIE)?.value;

let pendingChallenges = 0;
if (profile) {
  const { count } = await supabase
    .from('challenges')
    .select('id', { count: 'exact', head: true })
    .eq('challenged_id', profile.id)
    .eq('status', 'pending');
  pendingChallenges = count ?? 0;
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | PvP Arena</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
</head>
<body>
  {isImpersonating && (
    <div style="
      background: var(--mc-gold);
      color: #000;
      font-family: 'Press Start 2P', monospace;
      font-size: 9px;
      padding: 8px 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      border-bottom: 3px solid #000;
    ">
      <span>&#128065; VISTA COMO: {profile?.username}</span>
      <form method="POST" action="/api/admin/stop-impersonate" style="display:inline;">
        <button type="submit" style="
          background: #000;
          color: var(--mc-gold);
          border: none;
          font-family: inherit;
          font-size: 8px;
          padding: 4px 10px;
          cursor: pointer;
        ">Salir de vista previa</button>
      </form>
    </div>
  )}
  {showNav && (
    <nav class="mc-nav">
      <a href="/" class="mc-nav-logo">&#9888; PvP Arena</a>
      <div class="mc-nav-links">
        <a href="/" class:list={[{ active: pathname === '/' }]}>Inicio</a>
        <a href="/ranking" class:list={[{ active: pathname === '/ranking' }]}>Ranking</a>
        {isLoggedIn && (
          <a href="/challenges" class:list={[{ active: pathname.startsWith('/challenges') }]}
             style="position: relative;">
            Retos
            {pendingChallenges > 0 && (
              <span style="
                position: absolute;
                top: -6px; right: -10px;
                background: var(--mc-red);
                color: #fff;
                font-size: 8px;
                padding: 2px 5px;
                border-radius: 0;
                font-family: inherit;
                border: 1px solid #000;
              ">{pendingChallenges}</span>
            )}
          </a>
        )}
        {isAdmin && (
          <a href="/admin" class:list={[{ active: pathname.startsWith('/admin') }]}>Admin</a>
        )}
        {isLoggedIn ? (
          <a href="/auth/signout" class="btn btn-red btn-sm">Salir</a>
        ) : (
          <a href="/login" class="btn btn-green btn-sm">Entrar</a>
        )}
      </div>
    </nav>
  )}
  <slot />
</body>
</html>
