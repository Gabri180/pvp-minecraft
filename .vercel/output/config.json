			"src": "^/api/admin/add-battle/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/create-user/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/delete-battle/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/delete-user/?$",
			"dest": "_render"
